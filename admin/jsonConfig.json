{
    "type": "panel",
    "i18n": true,
    "items": {
        "enableLocal": {
            "type": "checkbox",
            "label": "enableLocal",
            "default": true,
            "sm": 12,
            "help": "enableLocalHelp"
        },
        "host": {
            "type": "text",
            "label": "dtuHost",
            "placeholder": "192.168.1.100",
            "sm": 6,
            "hidden": "!data.enableLocal",
            "validator": "!data.enableLocal || data.host !== ''",
            "validatorErrorText": "hostRequired",
            "help": "dtuHostHelp"
        },
        "pollInterval": {
            "type": "number",
            "label": "pollInterval",
            "default": 30,
            "min": 10,
            "max": 300,
            "sm": 6,
            "hidden": "!data.enableLocal",
            "help": "pollIntervalHelp"
        },
        "cloudPause": {
            "type": "checkbox",
            "label": "cloudPause",
            "default": true,
            "sm": 6,
            "hidden": "!data.enableLocal",
            "help": "cloudPauseHelp"
        },
        "cloudPauseDuration": {
            "type": "number",
            "label": "cloudPauseDuration",
            "default": 40,
            "min": 20,
            "max": 120,
            "sm": 6,
            "hidden": "!data.enableLocal || !data.cloudPause",
            "help": "cloudPauseDurationHelp"
        },
        "_divider1": {
            "type": "divider",
            "sm": 12
        },
        "enableCloud": {
            "type": "checkbox",
            "label": "enableCloud",
            "default": false,
            "sm": 12,
            "help": "enableCloudHelp"
        },
        "cloudUser": {
            "type": "text",
            "label": "cloudUser",
            "placeholder": "email@example.com",
            "sm": 6,
            "hidden": "!data.enableCloud",
            "validator": "!data.enableCloud || data.cloudUser !== ''",
            "validatorErrorText": "cloudUserRequired"
        },
        "cloudPassword": {
            "type": "password",
            "label": "cloudPassword",
            "sm": 6,
            "hidden": "!data.enableCloud",
            "validator": "!data.enableCloud || data.cloudPassword !== ''",
            "validatorErrorText": "cloudPasswordRequired"
        },
        "cloudPollInterval": {
            "type": "number",
            "label": "cloudPollInterval",
            "default": 300,
            "min": 60,
            "max": 3600,
            "sm": 6,
            "hidden": "!data.enableCloud",
            "help": "cloudPollIntervalHelp"
        },
        "_cloudInfo": {
            "type": "staticText",
            "text": "cloudInfo",
            "sm": 12,
            "hidden": "!data.enableCloud",
            "style": {
                "fontSize": 12,
                "opacity": 0.7
            }
        }
    }
}
