{
    "type": "panel",
    "i18n": true,
    "items": {
        "enableLocal": {
            "type": "checkbox",
            "label": "enableLocal",
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "default": true,
            "help": "enableLocalHelp"
        },
        "host": {
            "type": "text",
            "label": "dtuHost",
            "placeholder": "192.168.1.100",
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "disabled": "!data.enableLocal",
            "help": "dtuHostHelp"
        },
        "pollInterval": {
            "type": "number",
            "label": "pollInterval",
            "default": 0,
            "min": 0,
            "max": 300,
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "disabled": "!data.enableLocal",
            "help": "pollIntervalHelp"
        },
        "slowPollFactor": {
            "type": "number",
            "label": "slowPollFactor",
            "default": 6,
            "min": 1,
            "max": 60,
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "disabled": "!data.enableLocal",
            "help": "slowPollFactorHelp"
        },
        "_divider1": {
            "type": "divider",
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12
        },
        "enableCloud": {
            "type": "checkbox",
            "label": "enableCloud",
            "default": false,
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "help": "enableCloudHelp"
        },
        "cloudUser": {
            "type": "text",
            "label": "cloudUser",
            "placeholder": "email@example.com",
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "disabled": "!data.enableCloud",
            "validator": "!data.enableCloud || data.cloudUser !== ''",
            "validatorErrorText": "cloudUserRequired"
        },
        "cloudPassword": {
            "type": "password",
            "label": "cloudPassword",
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "disabled": "!data.enableCloud",
            "validator": "!data.enableCloud || data.cloudPassword !== ''",
            "validatorErrorText": "cloudPasswordRequired"
        },
        "cloudDtuSerial": {
            "type": "text",
            "label": "cloudDtuSerial",
            "placeholder": "4143A01CEDE4",
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "disabled": "!data.enableCloud || data.enableLocal",
            "help": "cloudDtuSerialHelp"
        },
        "cloudPollInterval": {
            "type": "number",
            "label": "cloudPollInterval",
            "default": 300,
            "min": 60,
            "max": 3600,
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "disabled": "!data.enableCloud",
            "help": "cloudPollIntervalHelp"
        },
        "_cloudInfo": {
            "type": "staticText",
            "text": "cloudInfo",
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "hidden": "!data.enableCloud",
            "style": {
                "fontSize": 12,
                "opacity": 0.7
            }
        }
    }
}
