{
	"extends": "@tsconfig/node20/tsconfig.json",
	"compilerOptions": {
		"outDir": "./build/",
		"removeComments": false,
		"sourceMap": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"noImplicitOverride": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["build/", "node_modules/"]
}
